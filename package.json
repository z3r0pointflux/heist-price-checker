{
  "name": "heistchecker",
  "version": "1.0.0",
  "description": "z3r0's Heist Price Checker - Path of Exile Heist curio display price checker using poe.ninja",
  "productName": "z3r0's Heist Price Checker",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "tsc && node -e \"const fs=require('fs');const path=require('path');['overlay.html','overlay.css','overlay-stack.html','overlay-stack.css','settings.html','settings.css'].forEach(f=>fs.copyFileSync(path.join('src','renderer',f),path.join('dist','renderer',f)))\" && electron .",
    "build": "tsc && node -e \"const fs=require('fs');const path=require('path');['overlay.html','overlay.css','overlay-stack.html','overlay-stack.css','settings.html','settings.css'].forEach(f=>fs.copyFileSync(path.join('src','renderer',f),path.join('dist','renderer',f)))\" && electron-builder",
    "compile": "tsc"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "fuse.js": "^7.0.0",
    "sharp": "^0.33.2",
    "tesseract.js": "^5.0.4"
  },
  "build": {
    "appId": "com.z3r0.heist-price-checker",
    "productName": "z3r0s Heist Price Checker",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "artifactName": "z3r0s-Heist-Price-Checker-Setup-${version}.exe"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      { "from": "assets/", "to": "assets/" }
    ]
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3"
  }
}
